<?xml version="1.0" encoding="utf-8" ?>
<Components:Component xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:Components="clr-namespace:MarquitoUtils.MAUI.Components;assembly=MarquitoUtils.MAUI"
    x:Class="MarquitoUtils.MAUI.Components.ComboBox"
    x:Name="Root">
    <StackLayout Orientation="Vertical" Margin="10">
        <Label 
            Text="{Binding Label, Source={x:Reference Root}}"
            VerticalOptions="Center" 
            HorizontalOptions="Start" />
        
        <Picker
            ItemsSource="{Binding ItemsSource, Source={x:Reference Root}}"
            SelectedItem="{Binding SelectedItem, Source={x:Reference Root}}"
            ItemDisplayBinding="{Binding ValueToDisplay}"/>
    </StackLayout>
</Components:Component>
