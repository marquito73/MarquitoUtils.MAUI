<Components:Component xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:Components="clr-namespace:MarquitoUtils.MAUI.Components;assembly=MarquitoUtils.MAUI"
    x:Class="MarquitoUtils.MAUI.Components.IconButton"
    x:Name="Root">
    <Button 
        Text="{Binding IconValue, Source={x:Reference Root}}"
        FontFamily="marquito"
        FontSize="{Binding FontSize, Source={x:Reference Root}}"
        TextColor="{Binding IconColor, Source={x:Reference Root}}"
        BackgroundColor="{Binding BackgroundColor, Source={x:Reference Root}}"
        Clicked="IconButton_Clicked"/>
</Components:Component>