<?xml version="1.0" encoding="utf-8" ?>
<FormComponents:FormComponent xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:Components="clr-namespace:MarquitoUtils.MAUI.Components;assembly=MarquitoUtils.MAUI"
    xmlns:FormComponents="clr-namespace:MarquitoUtils.MAUI.Components.Form;assembly=MarquitoUtils.MAUI"
    xmlns:SyncFusionComponents="clr-namespace:Syncfusion.Maui.Inputs;assembly=Syncfusion.Maui.Inputs"
    x:Class="MarquitoUtils.MAUI.Components.Form.ColorPicker"
    x:Name="Root">
    <StackLayout 
        Orientation="Vertical" 
        Margin="10"
        HeightRequest="64"
        Spacing="10">
        <VerticalStackLayout>
            <Label 
            Text="{Binding Label, Source={x:Reference Root}}"
            VerticalOptions="Center" 
            HorizontalOptions="Start" />

            <SyncFusionComponents:SfColorPicker
            IsEnabled="{Binding IsEnabled, Source={x:Reference Root}}"
            BackgroundColor="{Binding PickerBackgroundColor, Source={x:Reference Root}}"
            SelectedColor="{Binding PickerSelectedColor, Source={x:Reference Root}}"
            />
        </VerticalStackLayout>

        <HorizontalStackLayout
            Spacing="10"
            IsVisible="{Binding ErrorIsDisplayed, Source={x:Reference Root}}">
            <Components:IconComponent
                Icon="NOTIFICATION"
                IconColor="Red"
                />

            <Label
                Text="{Binding ErrorValue, Source={x:Reference Root}}"
                TextColor="Red"/>
        </HorizontalStackLayout>
    </StackLayout>
</FormComponents:FormComponent>
